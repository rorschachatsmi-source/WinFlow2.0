{
  "flow_name": "example_flow",
  "poll_interval": 10,
  "stages": [
    {
      "name": "preprocessing",
      "tasks": [
        {
          "name": "validate_inputs",
          "jobs": [
            {
              "name": "check_data",
              "command": "./example_flow/s1_t1_j1.sh",
              "queue": "tpdsd1",
              "cpu": 1,
              "inputs": ["example_flow/input.txt"],
              "outputs": ["temp.txt"]
            }
          ]
        }
      ]
    },
    {
      "name": "processing",
      "tasks": [
        {
          "name": "task_1",
          "jobs": [
            {
              "name": "process_part_1_1",
              "command": "./example_flow/s2_t1_j1.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": ["temp.txt"],
              "outputs": ["output_1.txt"]
            },
            {
              "name": "process_part_1_2",
              "command": "./example_flow/s2_t1_j2.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": ["temp.txt", "output_1.txt"],
              "outputs": ["output_1.txt"]
            }
          ]
        },
        {
          "name": "task_2",
          "jobs": [
            {
              "name": "process_part_2_1",
              "command": "./example_flow/s2_t2_j1.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": ["temp.txt"],
              "outputs": ["output_2.txt"]
            }
          ]
        }
      ]
    },
    {
      "name": "postprocessing",
      "tasks": [
        {
          "name": "merge_results",
          "jobs": [
            {
              "name": "merge",
              "command": "./example_flow/s3_t1_j1.sh",
              "queue": "tpdsd1",
              "cpu": 2,
              "inputs": ["output_1.txt", "output_2.txt"],
              "outputs": ["final_output.txt"]
            }
          ]
        }
      ]
    }
  ]
}
