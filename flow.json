{
  "flow_name": "PV",
  "poll_interval": 20,
  "stages": [
    {
      "name": "streamIn_APR",
      "tasks": [
        {
          "name": "TOP_MODULE_streamIn_APR",
          "jobs": [
            {
              "name": "06_postroute_opt",
              "command": "./run_stage 06_postroute_opt",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [],
              "outputs": [
                "06_postroute_opt/DB/06_postroute_opt.enc.dat"
              ]
            },
            {
              "name": "laker_In",
              "command": "../flow/bzgdsin_apr.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../DATA/apr.gds.gz",
                "06_postroute_opt/DB/06_postroute_opt.enc.dat"
              ],
              "outputs": [
                "../LakerBZ/TOP_MODULE_APR.blitz++"
              ]
            }
          ]
        },
        {
          "name": "SPI",
          "jobs": [
            {
              "name": "SPI",
              "command": "../flow/run_spi.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "TOP_MODULE.spi",
                "../DATA/netlist.pg.v.gz",
                "06_postroute_opt/DB/06_postroute_opt.enc.dat"
              ],
              "outputs": [
                "../spi/TOP_MODULE.cdl"
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "streamOut_APR",
      "tasks": [
        {
          "name": "TOP_MODULE_streamOut_APR",
          "jobs": [
            {
              "name": "laker_Out",
              "command": "../flow/bzgdsout_apr.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../LakerBZ/TOP_MODULE_APR.blitz++"
              ],
              "outputs": [
                "../GDS/TOP_MODULE_FULL.gds.gz"
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Merge",
      "tasks": [
        {
          "name": "laker_text",
          "jobs": [
            {
              "name": "laker_text",
              "command": "../flow/laker_text.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../LakerBZ/TOP_MODULE_APR.blitz++",
                "../GDS/TOP_MODULE_FULL.gds.gz"
              ],
              "outputs": [
                "../LakerBZ/create_text_from_APRgds.tcl"
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "streamOut_TOP",
      "tasks": [
        {
          "name": "TOP_MODULE_streamOut_TOP",
          "jobs": [
            {
              "name": "laker_topLib",
              "command": "../flow/laker_topLib.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../LakerBZ/create_text_from_APRgds.tcl",
                "../DATA/laker_topLib.tcl"
              ],
              "outputs": [
                "../LakerBZ/TOP_MODULE_LIB.blitz++"
              ]
            },
            {
              "name": "TOP_MODULE_Out",
              "command": "../flow/bzgdsout_top.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../LakerBZ/TOP_MODULE_LIB.blitz++",
                "../GDS/TOP_MODULE_FULL.gds.gz"
              ],
              "outputs": [
                "../GDS/TOP_MODULE.gds.gz"
              ]
            },
            {
              "name": "gds2oas",
              "command": "../flow/gds2oas.sh",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../GDS/TOP_MODULE.gds.gz"
              ],
              "outputs": [
                "../GDS/TOP_MODULE.oas"
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "DRC",
      "tasks": [
        {
          "name": "DRC",
          "jobs": [
            {
              "name": "DRC",
              "command": "../flow/run_drc DRC",
              "queue": "tpdsd1",
              "cpu": 4,
              "inputs": [
                "../GDS/TOP_MODULE.oas"
              ],
              "outputs": [
                "DRC.rep"
              ]
            }
          ]
        }
      ]
    }
  ]
}