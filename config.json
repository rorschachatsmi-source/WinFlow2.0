{
  "runner": {
    "default_flow_file": "flow.json",
    "session_log_dir": "logs",
    "session_log_file": "logs/flow_runner.log",
    "job_log_dir": "log",
    "poll_interval": 20,
    "default_queue": "tpdsd1",
    "default_cpu": 4,
    "logger_name": "FlowRunner",
    "kill_poll_ms": 15000,
    "kill_max_retries": 4,
    "log_tail_interval_sec": 0.5,
    "thread_join_timeout_sec": 1.0,
    "log_viewer": "gvim",
    "auto_load_delay_ms": 150
  },
  "lsf": {
    "bsub": "bsub",
    "bjobs": "bjobs",
    "bkill": "bkill",
    "bjobs_noheader": true,
    "bjobs_output_field": "stat",
    "job_name_timestamp_format": "%Y%m%d_%H%M%S"
  },
  "generator": {
    "default_flow_type": "pv",
    "default_setting_file": "setting.sh",
    "default_blocks_file": "block_stream.list",
    "default_output_file": "flow.json",
    "poll_interval": 20,
    "default_queue": "tpdsd1",
    "default_cpu": 4,
    "blank_flow_name": "custom_flow",
    "new_job_cpu": 1
  },
  "pv": {
    "flow_name": "PV",
    "required_settings": ["TOP_MODULE", "MACHINE_QUEUE", "MACHINE_CPU"],
    "paths": {
      "laker_dir": "../LakerBZ",
      "gds_dir": "../GDS",
      "flow_dir": "../flow",
      "data_dir": "../DATA",
      "spi_dir": "../spi"
    },
    "scripts": {
      "sub_bzgdsin_apr": "sub_bzgdsin_apr.sh",
      "sub_calibre_dm": "sub_calibre_dm.sh",
      "bzgdsin_apr": "bzgdsin_apr.sh",
      "pre_bzgdsin_apr": "pre_bzgdsin_apr.sh",
      "bzgdsout_apr": "bzgdsout_apr.sh",
      "laker_topLib": "laker_topLib.sh",
      "bzgdsout_top": "bzgdsout_top.sh",
      "gds2oas": "gds2oas.sh",
      "laker_text": "laker_text.sh",
      "run_drc": "run_drc",
      "spi": "run_spi.sh",
      "rcxt": "run_rcxt.sh",
      "lvs": "run_lvs.sh"
    },
    "files": {
      "apr_gds": "{data_dir}/apr.gds.gz",
      "apr_blitz": "{laker_dir}/{top}_APR.blitz++",
      "full_gds": "{gds_dir}/{top}_FULL.gds.gz",
      "sub_block_gds": "{workdir}/GDS/{block}.gds.gz",
      "sub_block_blitz": "{laker_dir}/{block}.blitz++",
      "sub_dmexcl_calibre": "{laker_dir}/sub_dmexcl.calibre",
      "sub_dummy_gds": "{laker_dir}/{block}_dummy.gds.gz",
      "create_text_tcl": "{laker_dir}/create_text_from_APRgds.tcl",
      "laker_top_lib_tcl": "{data_dir}/laker_topLib.tcl",
      "merge_tag_gds": "{gds_dir}/{tag}.gds",
      "merge_tag_gds_gz": "{gds_dir}/{tag}.gds.gz",
      "merge_blitz": "{laker_dir}/{top}_{tag}.blitz++",
      "lib_blitz": "{laker_dir}/{final_top}_LIB.blitz++",
      "final_gds": "{gds_dir}/{final_top}.gds.gz",
      "final_oas": "{gds_dir}/{final_top}.oas",
      "spi_inputs": [
        "{top}.spi",
        "{data_dir}/netlist.pg.v.gz"
      ],
      "spi_outputs": [
        "{spi_dir}/{top}.cdl"
      ],
      "rcxt_inputs": [
        "{gds_dir}/DM.gds"
      ],
      "rcxt_outputs": [
        "flag_starrc_done"
      ],
      "lvs_inputs": [
        "hcell",
        "lvs.calibre",
        "layout.spi",
        "{gds_dir}/{final_top}.oas",
        "{spi_dir}/{top}.cdl"
      ],
      "lvs_outputs": [
        "lvs.rep"
      ],
      "drc_report": "DRC.rep"
    },
    "merge_flags": [
      {"setting_key": "FLAG_DMF", "script": "dmf", "tag": "DM"},
      {"setting_key": "FLAG_DOD", "script": "dod", "tag": "DODPO"},
      {"setting_key": "FLAG_DEX", "script": "dex", "tag": "DMEXCL"}
    ]
  },
  "apr": {
    "flow_name": "APR",
    "stage_name": "APR",
    "task_name": "apr",
    "run_stage_template": "./run_stage {job_name}",
    "output_template": "{job_name}/DB/{job_name}.enc.dat",
    "stages_before_current": [
      "01_floorplan",
      "02_prects_opt",
      "03_cts_concurrent"
    ],
    "current_stage": "04_postcts_opt",
    "stages_after_current": [
      "05_route.tcl",
      "06_postroute_opt"
    ],
    "default_queue": "tpdsd1",
    "default_cpu": "4"
  },
  "gui": {
    "generator_window_size": "1280x800",
    "generator_window_min": "960x640",
    "runner_window_size": "1280x820",
    "sidebar_min_width": 220
  }
}
