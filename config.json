{
  "runner": {
    "default_flow_file": "flow.json",
    "session_log_dir": "logs",
    "session_log_file": "logs/flow_runner.log",
    "job_log_dir": "log",
    "poll_interval": 20,
    "default_queue": "tpdsd1",
    "default_cpu": 4,
    "logger_name": "FlowRunner",
    "kill_poll_ms": 15000,
    "kill_max_retries": 4,
    "log_tail_interval_sec": 0.5,
    "thread_join_timeout_sec": 1.0,
    "log_viewer": "gvim",
    "auto_load_delay_ms": 150
  },
  "lsf": {
    "bsub": "bsub",
    "bjobs": "bjobs",
    "bkill": "bkill",
    "bjobs_noheader": true,
    "bjobs_output_field": "stat",
    "job_name_timestamp_format": "%Y%m%d_%H%M%S"
  },
  "generator": {
    "default_flow_type": "pv",
    "default_setting_file": "setting.sh",
    "default_blocks_file": "block_stream.list",
    "default_output_file": "flow.json",
    "poll_interval": 20,
    "default_queue": "tpdsd1",
    "default_cpu": 4,
    "blank_flow_name": "custom_flow",
    "new_job_cpu": 1
  },
  "pv": {
    "flow_name": "PV",
    "required_settings": ["TOP_MODULE", "MACHINE_QUEUE", "MACHINE_CPU"],
    "paths": {
      "laker_dir": "../LakerBZ",
      "gds_dir": "../GDS",
      "flow_dir": "../flow",
      "data_dir": "../DATA",
      "spi_dir": "../spi"
    },
    "scripts": {
      "sub_bzgdsin_apr": "sub_bzgdsin_apr.sh",
      "sub_calibre_dm": "sub_calibre_dm.sh",
      "bzgdsin_apr": "bzgdsin_apr.sh",
      "pre_bzgdsin_apr": "pre_bzgdsin_apr.sh",
      "bzgdsout_apr": "bzgdsout_apr.sh",
      "laker_topLib": "laker_topLib.sh",
      "bzgdsout_top": "bzgdsout_top.sh",
      "gds2oas": "gds2oas.sh",
      "laker_text": "laker_text.sh",
      "run_drc": "run_drc",
      "spi": "run_spi.sh",
      "rcxt": "run_rcxt.sh",
      "lvs": "run_lvs.sh"
    },
    "jobs": {
      "sub_laker": {
        "inputs": ["{workdir}/GDS/{block}.gds.gz"],
        "outputs": ["{laker_dir}/{block}.blitz++"]
      },
      "sub_calibre": {
        "inputs": ["{laker_dir}/sub_dmexcl.calibre"],
        "outputs": ["{laker_dir}/{block}_dummy.gds.gz"]
      },
      "sub_laker_dummy": {
        "inputs": ["{laker_dir}/{block}_dummy.gds.gz"],
        "outputs": ["{laker_dir}/{block}.blitz++"]
      },
      "laker_In": {
        "inputs": ["{data_dir}/apr.gds.gz"],
        "outputs": ["{laker_dir}/{top}_APR.blitz++"]
      },
      "laker_In_from_stream_out": {
        "inputs": ["{gds_dir}/{top}_FULL.gds.gz"],
        "outputs": ["{laker_dir}/{top}_APR.blitz++"]
      },
      "laker_pre_In": {
        "inputs": ["{data_dir}/apr.gds.gz"],
        "outputs": ["{laker_dir}/{top}_APR.blitz++"]
      },
      "laker_Out": {
        "inputs": ["{laker_dir}/{top}_APR.blitz++"],
        "outputs": ["{gds_dir}/{top}_FULL.gds.gz"]
      },
      "SPI": {
        "inputs": ["{top}.spi", "{data_dir}/netlist.pg.v.gz"],
        "outputs": ["{spi_dir}/{top}.cdl"]
      },
      "RCXT": {
        "inputs": ["{gds_dir}/DM.gds"],
        "outputs": ["flag_starrc_done"]
      },
      "LVS": {
        "inputs": [
          "hcell",
          "lvs.calibre",
          "layout.spi",
          "{gds_dir}/{final_top}.oas",
          "{spi_dir}/{top}.cdl"
        ],
        "outputs": ["lvs.rep"]
      },
      "Calibre_merge": {
        "inputs": ["{gds_dir}/{top}_FULL.gds.gz"],
        "outputs": ["{gds_dir}/{tag}.gds"]
      },
      "Calibre_merge_gz": {
        "inputs": ["{gds_dir}/{top}_FULL.gds.gz"],
        "outputs": ["{gds_dir}/{tag}.gds.gz"]
      },
      "laker_merge": {
        "inputs": ["{gds_dir}/{tag}.gds"],
        "outputs": ["{laker_dir}/{top}_{tag}.blitz++"]
      },
      "laker_text": {
        "inputs": [
          "{laker_dir}/{top}_APR.blitz++",
          "{gds_dir}/{top}_FULL.gds.gz"
        ],
        "outputs": ["{laker_dir}/create_text_from_APRgds.tcl"]
      },
      "laker_topLib": {
        "inputs": [
          "{laker_dir}/{top}_DM.blitz++",
          "{laker_dir}/create_text_from_APRgds.tcl",
          "{data_dir}/laker_topLib.tcl"
        ],
        "outputs": ["{laker_dir}/{final_top}_LIB.blitz++"]
      },
      "top_Out": {
        "inputs": [
          "{laker_dir}/{final_top}_LIB.blitz++",
          "{gds_dir}/{top}_FULL.gds.gz"
        ],
        "outputs": ["{gds_dir}/{final_top}.gds.gz"]
      },
      "gds2oas": {
        "inputs": ["{gds_dir}/{final_top}.gds.gz"],
        "outputs": ["{gds_dir}/{final_top}.oas"]
      },
      "DRC": {
        "inputs": ["{gds_dir}/{final_top}.oas"],
        "outputs": ["DRC.rep"]
      },
      "DRC_BE": {
        "inputs": ["{gds_dir}/{final_top}.oas"],
        "outputs": ["DRC.rep"]
      },
      "DRC_FE": {
        "inputs": ["{gds_dir}/{final_top}.oas"],
        "outputs": ["DRC.rep"]
      },
      "merge_topLib_extras": {
        "inputs": [
          "{laker_dir}/create_text_from_APRgds.tcl",
          "{data_dir}/laker_topLib.tcl"
        ],
        "outputs": []
      }
    },
    "merge_flags": [
      {"setting_key": "FLAG_DMF", "script": "dmf", "tag": "DM"},
      {"setting_key": "FLAG_DOD", "script": "dod", "tag": "DODPO"},
      {"setting_key": "FLAG_DEX", "script": "dex", "tag": "DMEXCL"}
    ]
  },
  "apr": {
    "flow_name": "APR",
    "stage_name": "APR",
    "task_name": "apr",
    "default_job": {
      "command": "./run_stage {job_name}",
      "inputs": ["{prev_output}"],
      "outputs": ["{job_name}/DB/{job_name}.enc.dat"]
    },
    "jobs": {
      "01_floorplan": {
        "inputs": []
      },
      "02_prects_opt": {},
      "03_cts_concurrent": {},
      "04_postcts_opt": {},
      "05_route.tcl": {},
      "06_postroute_opt": {}
    },
    "stages_before_current": [
      "01_floorplan",
      "02_prects_opt",
      "03_cts_concurrent"
    ],
    "current_stage": "04_postcts_opt",
    "stages_after_current": [
      "05_route.tcl",
      "06_postroute_opt"
    ],
    "default_queue": "tpdsd1",
    "default_cpu": "4"
  },
  "gui": {
    "generator_window_size": "1280x800",
    "generator_window_min": "960x640",
    "runner_window_size": "1280x820",
    "sidebar_min_width": 220
  }
}
